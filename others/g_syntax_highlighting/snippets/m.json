{
  "Initialize Project": {
    "prefix": [
      "func",
      "",
      ".",
      "main",
      "Main",
      "init",
      "module",
      "project"
    ],
    "body": [
      "func ${1:project_name}() -> METAVOID {",
      "  $0",
      "}"
    ],
    "description": "Insert a Mawin function declaration."
  },
  "Version": {
    "prefix": "version",
    "body": [
      "version := r\"${1:0.0.1}\"$0"
    ],
    "description": "Insert a Mawin version declaration"
  },
  "Dependencies": {
    "prefix": "dependencies",
    "body": [
      "// needs links if public or file paths if local",
      "dependencies := {",
      "\tr\"${1:dependency_one}\",",
      "\tr\"${2:other_dependencies}\"",
      "}$0"
    ],
    "description": "Insert a Mawin dependency list to fill"
  },
  "Exclude": {
    "prefix": "exclude",
    "body": [
      "// needs file paths",
      "exclude := {",
      "\tr\"${1:filepath_one}\",",
      "\tr\"${2:filepath_two}\"",
      "}$0"
    ],
    "description": "Insert a Mawin exclude list to fill"
  },
  "Project": {
    "prefix": "project",
    "body": [
      "project := r\"${1:my_project}\"$0"
    ],
    "description": "Insert a Mawin project name string"
  }
}
