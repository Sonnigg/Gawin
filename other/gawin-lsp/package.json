{
  "name": "gawin-lsp",
  "version": "0.1.0",
  "description": "Language Server and VS Code extension for Gawin",
  "repository": {
    "type": "git",
    "url": "https://github.com/gawin/gawin-lsp"
  },
  "main": "server/out/server.js",
  "scripts": {
    "build": "npm run -s build:server && npm run -s build:client && npx cpx \"server/out/**\" client/server_out -C",
    "build:server": "tsc -p server/",
    "build:client": "npm --prefix client run build",
    "watch:server": "tsc -p server/ -w",
    "watch:client": "npm --prefix client run build",
    "validate": "npm run build && npm test",
    "test": "mocha --require ts-node/register --extensions ts \"server/test/**/*.test.ts\" --exit",
    "package:vsix": "npm run build && npm --prefix client ci && npm --prefix client run -s build && cd client && npx vsce package -o ..\\gawin-lsp.vsix",
    "package:all": "npm ci && npm run -s build && npm --prefix client ci && npm --prefix client run -s build && cd client && npx vsce package -o ..\\gawin-lsp.vsix",
    "package": "npm run package:vsix"
  },
  "keywords": [
    "gawin",
    "language-server",
    "lsp",
    "vscode"
  ],
  "author": "gawin-lsp-team",
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "devDependencies": {
    "@types/mocha": "^9.0.0",
    "@types/node": "^18.0.0",
    "cpx": "^1.2.1",
    "mocha": "^8.1.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "vsce": "^1.25.1"
  },
  "contributes": {
    "semanticTokenScopes": [
      {
        "language": "gawin",
        "scopes": {
          "keyword": [
            "keyword.control.gawin"
          ],
          "type": [
            "storage.type.gawin"
          ],
          "variable": [
            "variable.other.gawin"
          ],
          "function": [
            "entity.name.function.gawin"
          ]
        }
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^8.0.0",
    "vscode-languageserver": "^8.0.0",
    "vscode-languageserver-protocol": "^3.17.0",
    "vscode-languageserver-textdocument": "^1.0.0"
  }
}
